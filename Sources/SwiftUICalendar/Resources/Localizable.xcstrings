      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Secondary %@"
          }
        }
      }
    },
    "Calendar.Day.Selected": {
      "comment": "VoiceOver trait appended to a day cell that is currently selected",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Selected"
          }
        }
      }
    },
    "Calendar.Day.Today": {
      "comment": "VoiceOver trait appended to the day cell representing today",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Today"
          }
        }
      }
    },
    "Calendar.Navigation.Next": {
      "comment": "VoiceOver label for the button that advances to the next month/year",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next"
          }
        }
      }
    },
    "Calendar.Navigation.Previous": {
      "comment": "VoiceOver label for the button that returns to the previous month/year",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Previous"
          }
        }
      }
    },
    "Calendar.Today": {
      "comment": "Button to jump to today's date\"",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Today"
          }
        }
      }
    },
    "Calendar.Navigation.Year.Selected": {
      "comment": "VoiceOver label announcing the currently selected year, e.g. \"Selected year, 2026\"",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Selected year, %@"
          }
        }
      }
    },
    "Calendar.Navigation.Year.ChangeHint": {
      "comment": "VoiceOver hint describing that activating the control lets the user change the selected year",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Double tap to change the selected year"
          }
        }
      }
